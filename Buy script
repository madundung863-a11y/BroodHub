local function IsStandSelected(stand)
    if next(selectedStands) == nil then return true end
    return selectedStands[stand] == true
end

local function IsAttrSelected(attr)
    if next(selectedAttrs) == nil then return true end
    return selectedAttrs[attr] == true
end

local farmTask = nil

function StartFarm()
    if farmTask then return end
    
    LocalPlayer:SetAttribute("ItemSkipConfirmationOn", true)
    LocalPlayer:SetAttribute("ItemAttributeConfirmationOn", false)
    LocalPlayer:SetAttribute("ItemStandConfirmationOn", false)
    
    farmTask = task.spawn(function()
        while FarmEnabled do
            UpdateParagraphs()
            
            local stand = GetCurrentStand()
            local attr = GetCurrentAttribute()
            
            if stand and stand ~= "None" then
                RollParagraph:SetDesc("Выпало: " .. stand .. " | " .. (attr or "None"))
                WindUI:Notify({
                    Title = "Новый ролл",
                    Content = "Стенд: " .. stand .. "\nАтрибут: " .. (attr or "None"),
                    Duration = 2
                })
            end
            
            local standMatch = IsStandSelected(stand)
            local attrMatch = IsAttrSelected(attr)
            
            if standMatch and attrMatch and stand and stand ~= "None" then
                RollParagraph:SetDesc("ГОТОВО! " .. stand .. " | " .. (attr or "None"))
                WindUI:Notify({
                    Title = "Фарм завершен!",
                    Content = "Стенд: " .. stand .. "\nАтрибут: " .. (attr or "None"),
                    Duration = 5
                })
                FarmEnabled = false
                break
            end
            
            if stand and stand ~= "None" then
                local roka = FindItemInBackpack("Rokakaka")
                if roka then
                    Send:FireServer("Item", "Rokakaka")
                    task.wait(1.5)
                elseif FarmTpEnabled then
                    local rokaPart = FindItemInAllSpawns("Rokakaka")
                    if rokaPart then
                        TeleportToItem(rokaPart)
                        task.wait(1)
                    else
                        task.wait(3)
                    end
                else
                    task.wait(3)
                end
            else
                local arrow = FindItemInBackpack(selectedArrow)
                if arrow then
                    Send:FireServer("Item", selectedArrow)
                    task.wait(1.5)
                elseif FarmTpEnabled then
                    local arrowPart = FindItemInAllSpawns(selectedArrow)
                    if arrowPart then
                        TeleportToItem(arrowPart)
                        task.wait(1)
                    else
                        task.wait(3)
                    end
                else
                    task.wait(3)
                end
            end
            
            task.wait(0.3)
        end
        farmTask = nil
    end)
end

local tpTasks = {}

function StartTpLoop(itemName)
    if tpTasks[itemName] then return end
    
    tpTasks[itemName] = task.spawn(function()
        while tpStates[itemName] do
            local item = FindItemInAllSpawns(itemName)
            if item then
                TeleportToItem(item)
            end
            task.wait(0.5)
        end
        tpTasks[itemName] = nil
    end)
end
