local function GetCurrentAttribute()
    local stats = LocalPlayer.Data and LocalPlayer.Data.Stats
    if stats and stats.Attribute and stats.Attribute.Value then
        return stats.Attribute.Value
    end
    return nil
end

local function GetCurrentStand()
    local stats = LocalPlayer.Data and LocalPlayer.Data.Stats
    if stats and stats.Ability and stats.Ability.Value then
        return stats.Ability.Value
    end
    return nil
end

local function FindItemInBackpack(itemName)
    local item = LocalPlayer.Backpack and LocalPlayer.Backpack:FindFirstChild(itemName)
    if item then return item end
    if LocalPlayer.Data and LocalPlayer.Data:FindFirstChild("Backpack") then
        item = LocalPlayer.Data.Backpack:FindFirstChild(itemName)
        if item then return item end
    end
    return nil
end

local function FindItemInAllSpawns(itemName)
    local spawns = Workspace.World.Map.ItemSpawns
    for _, child in ipairs(spawns:GetChildren()) do
        local item = child:FindFirstChild(itemName)
        if item then return item end
    end
    return nil
end

local function GetPositionFromItem(item)
    if item:IsA("BasePart") then
        return item.Position
    elseif item:IsA("Tool") then
        local handle = item:FindFirstChild("Handle")
        if handle and handle:IsA("BasePart") then
            return handle.Position
        end
    end
    return nil
end

local function TeleportToItem(itemPart)
    local character = LocalPlayer.Character
    if not character then return false end
    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoidRootPart then return false end
    local pos = GetPositionFromItem(itemPart)
    if not pos then return false end
    humanoidRootPart.CFrame = CFrame.new(pos + Vector3.new(0, 3, 0))
    return true
end

