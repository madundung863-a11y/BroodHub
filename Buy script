FPSText.Font = Drawing.Fonts.UI
FPSText.Visible = false
FPSText.ZIndex = 999

local fpsHistory = {}
local function updateFPS()
    local dt = RunService.RenderStepped:Wait()
    table.insert(fpsHistory, 1 / dt)
    if #fpsHistory > 60 then
        table.remove(fpsHistory, 1)
    end
    local sum = 0
    for _, v in ipairs(fpsHistory) do
        sum = sum + v
    end
    local avgFPS = math.floor(sum / #fpsHistory)
    local ping = Stats.Network.ServerStatsItem["Data Ping"]:GetValueString()
    return avgFPS, ping
end

local function StartFPSDrawer()
    task.spawn(function()
        while FPS_Enabled do
            local fps, ping = updateFPS()
            FPSText.Text = "FPS: " .. fps .. " | Пинг: " .. ping .. " мс"
            task.wait()
        end
    end)
end

